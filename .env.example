# Set this to enable the real Claude-powered ICP messaging review.
# Without it, the gate falls back to the heuristic reviewer automatically.
ANTHROPIC_API_KEY=

# Set these to publish organic social through Buffer (Instagram, Facebook,
# LinkedIn, X, TikTok, YouTube, Pinterest). Without them, Publish falls back to
# the mock publisher automatically.
#   BUFFER_PROFILE_IDS = JSON map of channel id -> Buffer profile id, e.g.
#   {"instagram":"5f...","linkedin":"6a..."}
BUFFER_ACCESS_TOKEN=
BUFFER_PROFILE_IDS=

# Set both to import from a real Google Drive (the "Drive" button + Connectors
# card use the native Google Picker). Without them, the Demo Drive fixture is
# used automatically. No app secret/backend — drive.file scope, the user's
# OAuth consent is the gate. From a Google Cloud project with the Picker API +
# Drive API enabled: create an OAuth client ID (Web) and a browser API key, and
# add your origin (http://localhost:5173 + prod domain) to both.
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=
