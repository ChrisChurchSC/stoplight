# Set this to enable real Claude across the app: ICP messaging review, copy
# generation, "Claude sets up the workspace", and Ask Claude. Without it, each
# falls back to its heuristic automatically. The dev server loads this file into
# the API handlers' process.env (see vite.config.ts), so just paste your key here
# and restart — no shell export needed.
ANTHROPIC_API_KEY=

# Set to pull a client's recent YouTube videos (titles + descriptions) into the
# current-state map during onboarding. A plain Google API key with the YouTube
# Data API v3 enabled (public data, no OAuth). Without it, onboarding skips
# YouTube. The client's channel is auto-discovered from links on their site.
YOUTUBE_API_KEY=

# Organic social (Instagram + LinkedIn) needs the client's OWN account connected
# via OAuth. These are the dev/manual path (a single connected account) for
# testing the readers before the per-client OAuth flow lands. See
# docs/social-oauth.md for how to register the apps and get a token.
#   Instagram: a Meta app token (instagram_basic + pages_show_list); the IG
#   account must be Business/Creator and linked to a Facebook Page.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=
#   LinkedIn: a token with r_organization_social; ORG_ID is the company page id
#   (numeric or full urn:li:organization:ID). VERSION is the LinkedIn-Version
#   month (YYYYMM); update to a currently-supported version.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=
LINKEDIN_VERSION=

# Set these to publish organic social through Buffer (Instagram, Facebook,
# LinkedIn, X, TikTok, YouTube, Pinterest). Without them, Publish falls back to
# the mock publisher automatically.
#   BUFFER_PROFILE_IDS = JSON map of channel id -> Buffer profile id, e.g.
#   {"instagram":"5f...","linkedin":"6a..."}
BUFFER_ACCESS_TOKEN=
BUFFER_PROFILE_IDS=

# Set all three to publish Email assets through Resend (each becomes a Resend
# broadcast draft). Without them, Email publish falls back to the mock automatically.
#   RESEND_AUDIENCE_ID = the audience the broadcast targets
#   RESEND_FROM_EMAIL  = a verified sender, e.g. "Acme <hello@acme.com>"
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
RESEND_FROM_EMAIL=

# Set both to import from a real Google Drive (the "Drive" button + Connectors
# card use the native Google Picker). Without them, the Demo Drive fixture is
# used automatically. No app secret/backend — drive.file scope, the user's
# OAuth consent is the gate. From a Google Cloud project with the Picker API +
# Drive API enabled: create an OAuth client ID (Web) and a browser API key, and
# add your origin (http://localhost:5173 + prod domain) to both.
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=

# Set both to put the app on the real Supabase backend (multi-user, real auth,
# durable data, server-enforced access control via RLS). Without them, the app
# runs on localStorage (the mock adapters), unchanged. First: create a Supabase
# project, run supabase/schema.sql in its SQL editor, then paste the project URL
# and anon key here. The anon key is safe in the browser; RLS protects the data.
# See docs/backend-setup.md.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
